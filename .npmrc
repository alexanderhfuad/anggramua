# npm configuration for Hostinger deployment

# Skip optional dependencies to avoid rebuild errors on shared hosting
optional=false

# Use legacy peer deps to avoid conflicts
legacy-peer-deps=true

# Timeout settings for slow connections
fetch-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Disable scripts to prevent build failures on shared hosting
ignore-scripts=false

# Use pre-built binaries when available
force-node-preload=false

