# npm configuration for Hostinger deployment

# Force npm to rebuild optional dependencies (fixes Rollup native modules)
legacy-peer-deps=false

# Timeout settings for slow connections
fetch-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Force rebuild of native modules after install
# This helps with @rollup/rollup-linux-x64-gnu on Linux servers

